# Copy this file (env.example) to tools/syncserver/.env and fill in real values.
# tools/syncserver/.env is git-ignored — never commit real secrets.

# Optional: username:password for the collection-sync server (default mcat:mcat).
# Normally set inline instead, e.g. `SYNC_USER1=me:secret just sync-server`.
# SYNC_USER1=mcat:mcat
