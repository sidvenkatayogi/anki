# Copy this file (env.example) to tools/syncserver/.env and fill in real values.
# tools/syncserver/.env is git-ignored — never commit real secrets.

# --- Read/Practice tab (mcat-tools sidecar) --------------------------------

# Required: OpenAI API key for Read-tab LLM quiz generation (server-side only, never shipped to clients).
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: only used if the Wikipedia passage source is exhausted and the news-API fallback tier is reached. Leave blank to disable that tier.
NEWS_API_KEY=

# Required: shared bearer secret gating the new /read, /practice, /metrics endpoints. Clients send it as header X-Mcat-Token. Generate a random string, distinct from SYNC_USER1.
MCAT_TOOLS_TOKEN=REPLACE_ME_WITH_RANDOM_TOKEN

# --- Existing sync server (for reference; normally set via SYNC_USER1=... just sync-server) ---

# Optional: username:password for the collection-sync server (default mcat:mcat).
# SYNC_USER1=mcat:mcat
